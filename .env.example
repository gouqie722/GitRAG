# DeepSeek (对话)
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
CHAT_MODEL=deepseek-chat

# Embedding 方案（三选一，见 README）
#
# 方案 A - 离线本地模型（推荐，无需额外 Key）
#   1. 运行 npm run download-model
#   2. 使用以下配置
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=Xenova/multilingual-e5-small
#
# 方案 B - SiliconFlow API（国内网络友好，需注册 Key）
# EMBEDDING_PROVIDER=siliconflow
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_MODEL=BAAI/bge-m3
#
# 方案 C - 其他 OpenAI 兼容 Embedding API
# EMBEDDING_PROVIDER=api
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_BASE_URL=https://api.xxx.com/v1
# EMBEDDING_MODEL=your-embedding-model

# LanceDB（本地嵌入式向量库，无需 Docker）
LANCEDB_PATH=./data/lancedb
LANCEDB_TABLE=github_repos

# GitHub
GITHUB_TOKEN=ghp_xxx
GITHUB_REPOS=your-username/project-a,your-username/project-b
AUTO_INDEX_ON_STARTUP=true
REINDEX_ON_STARTUP=false

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# RAG settings
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
TOP_K=8

# Agent (LangChain)
AGENT_MAX_STEPS=5
AGENT_HISTORY_LIMIT=10
